{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlimTransfer",
  "version": "0.1.0",
  "identifier": "com.slimtransfer.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "dist",
    "devUrl": "http://127.0.0.1:5000/"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 SlimTransfer",
    "category": "Utility",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      }
    }
  }
}
