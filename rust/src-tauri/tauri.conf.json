{
  "$schema": "https://schemas.tauri.app/config/2",
  "productName": "Tiny Transfer",
  "version": "0.1.0",
  "identifier": "com.tinytransfer.app",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../frontend",
    "beforeBuildCommand": "python ../../scripts/build-icons.py && npm run build --prefix ../../frontend",
    "frontendDist": "dist",
    "devUrl": "http://127.0.0.1:5173/"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "TinyTransfer",
        "width": 1100,
        "height": 780,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/windows/32x32.png",
      "icons/windows/128x128.png",
      "icons/windows/128x128@2x.png",
      "icons/windows/icon.ico"
    ],
    "copyright": "© 2026 TinyTransfer",
    "category": "Utility",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      }
    }
  }
}
